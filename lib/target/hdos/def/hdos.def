;
; HOSDEF definitions for HEATH/ZENITH HDOS
;

    ; System Call (SCALL) functions use RST $38 followed by a function byte (defb)
    ; ..or an equivalent drop-in couple of bytes : defb $ff,code

    defc    EXIT      = 0      ; Exit User Program
    defc    SCIN      = 1      ; System Console INput
    defc    SCOUT     = 2      ; System Console OUTput
    defc    PRINT     = 3      ; Print Line on System Console
    defc    READ      = 4      ; Read From File
    defc    WRITE     = 5      ; Write to Open File
    defc    CONSL     = 6      ; Set Console Mode Bits (see below)
    defc    CLRCO     = 7      ; Clear Console Buffer
    defc    LOADO     = 8      ; Load Overlay
    defc    VERS      = 9      ; HDOS Version Number

    defc    CHFLG     = $30    ; Change File Flags
    defc    CTLC      = $21    ; Set Up Handlers for Control Characters
    defc    CLEAR     = $2D    ; Clear I/O Channel
    defc    CLOSE     = $26    ; Close Channel
    defc    DECODE    = $2B    ; Decode File Name
    defc    DELETE    = $28    ; Delete Disk File
    defc    DMNMS     = $83    ; Dismount Disk with No Message
    defc    DMOUN     = $81    ; Dismount Disk
    defc    ERROR     = $2F    ; Print Error Message
    defc    LINK      = $20    ; Link to Another Program
    defc    LOADD     = $32    ; Load Device Driver
    defc    MOMNS     = $82    ; Mount Disk with No Message
    defc    MOUNT     = $80    ; Mount Disk
    defc    NAME      = $2C    ; Get File Name from Channel
    defc    OPENR     = $22    ; Open File for Read
    defc    OPENU     = $24    ; Open File for Update
    defc    OPENW     = $23    ; Open File for Write
    defc    POSIT     = $27    ; Position Disk File
    defc    RENAME    = $29    ; Rename Disk File
    defc    RESET     = $84    ; Dismount+Mount Disk (reset it)
    defc    SETTOP    = $2A    ; Set Top of User Memory
    defc    _VERS     = $16

    ;; HDOS equates
    ;; defc    USERFWA   = $4480  ; FIRST WORD ADDRESS FOR USER PROGRAMS
    ;; defc    STACK     = $4480  ; SYSTEM STACK ADDRESS

    ; These values are located in the reserved HDOS RAM area.
    defc    S_DATE    = $40BF  ; SYSTEM DATE (IN ASCII)
    defc    S_DATC    = $40C8  ; CODE DATE
    defc    S_HIMEM   = $40CE  ; HARDWARE HIGH MEMORY ADDRESS+1
    defc    S_SYSM    = $40D0  ; FWA RESIDENT SYSTEM
    defc    S_USRM    = $40D2  ; LWA USER MEMORY
    defc    S_OMAX    = $40D4  ; MAX OVERLAY SIZE FOR SYSTEM

    ; --------------------------------------------------------
    ; The following symbols are used by the "CONSL" SCALL
    ; --------------------------------------------------------
    defc    I_CSLMD   = 0    ; CONSOLE MODE
        defc    CSL_ECH   = 128  ; SUPPRESS ECHO
        defc    CSL_WRP   = 2    ; WRAP LINES AT WIDTH
        defc    CSL_CHR   = 1    ; OPERATE IN CHARACTER MODE
    
    defc    I_CONTY   = 1    ; S_CONTY IS 2ND BYTE
        defc    CTP_BKS   = 128  ; TERMINAL PROCESSES BACKSPACES
        defc    CTP_MLI   = 32   ; MAP LOWER CASE TO UPPER ON INPUT
        defc    CTP_ML0   = 16   ; MAP LOWER CASE TO UPPER ON OUTPUT
        defc    CTP_2SB   = 8    ; TERMINAL NEEDS TWO STOP BITS
        defc    CTP_BKM   = 2    ; MAP BKSP (UPON INPUT) TO RUBOUT
        defc    CTP_TAB   = 1    ; TERMINAL SUPPORTS TAB CHARACTERS

    defc    I_CUSOR   = 2    ; S_CUSOR IS 3RD BYTE
    defc    I_CONWI   = 3    ; S_CONWI IS 4TH BYTE
    defc    I_CONFL   = 4    ; S_CONFL IS 5TH BYTE
        defc    CO_FLG    = 1    ; CTL_O FLAG
        defc    CS_FLG    = 128  ; CTL_S FLAG
   ; --------------------------------------------------------
