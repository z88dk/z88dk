;;
;; Local label jump or call
;; jp n$
;; jr n$
;; call n$
;;
%"[ \t]*"0%"(jp|jr|call)"1%"[ \t]+"2%"[0-9]+"3$
=
%0%1%2@__sdcc_local_%3

%"[ \t]*"0%"(jp|jr|call)"1%"[ \t]+"2%"[0-9]+"3$%"[ \t]*"7%"(\+|-)"8%9
=
%0%1%2@__sdcc_local_%3%7%8%9

%1,%"[ \t]*"2%"[0-9]+"0$
=
