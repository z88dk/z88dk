;;
;; Convert n$: -> @__sdcc_local_n:
;;
%title Convert n$: -> @__sdcc_local_n:
%"[ \t]*"1%"[0-9]+"0$:%2
=
%1@__sdcc_local_%0:%2

%"[ \t]*"1%0$:%2
=
