%1#>(%0)
=
%1#((%0) / 256)

%1(#<(%0))
=
%1(#((%0) & 0xFF))

%1(#>(%0))
=
%1(#((%0) / 256))

%1<((%0))
=
%1#((%0) & 0xFF)

%1>((%0))
=
%1#((%0) / 256)

%1(<((%0)))
=
%1(#((%0) & 0xFF))

%1(>((%0)))
=
%1(#((%0) / 256))

%1#<%0
=
%1#((%0) & 0xFF)

%1#>%0
=
%1#((%0) / 256)

