




	INCLUDE "z80_crt0.hdr"


	SECTION	code_compiler

._main
	dec	sp
	pop	hl
	ld	l,0
	push	hl
.i_4
	call	l_gint3sp	;
	ld	de,2
	ex	de,hl
	call	l_gt
	jp	nc,i_5	;
	ld	hl,0	;const
	add	hl,sp
	ld	(hl),15
.i_5
	pop	hl
	push	hl
	ld	h,0
	inc	sp
	ret


	SECTION	bss_compiler
	SECTION	code_compiler
	defc	i_2 = i_5
	defc	i_3 = i_5



	SECTION	bss_compiler
	SECTION	code_compiler



	GLOBAL	_main




