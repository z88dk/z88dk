




	INCLUDE "z80_crt0.hdr"


	SECTION	code_compiler

._main
	dec	sp
	ld	hl,0	;const
	add	hl,sp
	ld	(hl),0
	jp	i_4	;EOS
.i_2
	ld	hl,0	;const
	add	hl,sp
	push	hl
	call	l_gchar
	inc	hl
	pop	de
	ld	a,l
	ld	(de),a
.i_4
	ld	hl,0	;const
	add	hl,sp
	call	l_gchar
	ld	a,l
	xor	128
	sub	160
	jp	c,i_2	;EOS
.i_3
	jp	i_3	;EOS
.i_6
	ld	hl,1	;const
	inc	sp
	ret


	SECTION	bss_compiler
	SECTION	code_compiler
	defc	i_5 = i_3



	SECTION	bss_compiler
	SECTION	code_compiler



	GLOBAL	_main




