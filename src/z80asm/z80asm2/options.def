// Help options
X(HELP,     "-h",      false, "", "Show this screen")
X(VERBOSE,  "-v",      false, "", "Verbose output")

// File and directory options
X(INCLUDE,  "-I",      true, "=DIR", "Add directory to search for source/include files")
X(OUTPUT,   "-O",      true, "=DIR", "Set directory to store output files")
// External preprocessor options
X(CPP,      "-cpp",    true, "=OPTS", "Pass options to cpp")
X(M4,       "-m4",     true, "=OPTS", "Pass options to m4")
X(PERL,     "-perl",   true, "=OPTS", "Pass options to perl")
// Preprocessor options
X(DEFINE,   "-D",      true, "=NAME[=EXPR]", "Define symbol")
X(PREPROC,  "-E",      false, "", "Preprocess only")

// Assembly options
X(IXIY,     "-IXIY",   false, "", "Swap IX and IY registers")
X(UCASE,    "-ucase",  false, "", "Uppercase labels")
X(DATESTAMP,"-d",      false, "", "Assemble only if newer")

// Diagnostic options
X(DUMP_AFTER_CMDLINE, "-dump-after-cmdline", false, "", "Dump the command line arguments and exit")
X(DUMP_AFTER_DIRECTIVES, "-dump-after-directives", false, "", "Dump the token stream after directive processing and exit")
X(DUMP_AFTER_MACRO_EXPANSION, "-dump-after-macro-expansion", false, "", "Dump the token stream after macro expansion and exit")
X(DUMP_AFTER_PREPROCESSING, "-dump-after-preprocessing", false, "", "Dump the final preprocessed token stream and exit")
X(DUMP_AFTER_TOKENIZATION, "-dump-after-tokenization", false, "", "Dump the lexer token stream and exit")
#undef X
