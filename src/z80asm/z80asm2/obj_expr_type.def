X(0,  Undefined,			0)     	// end marker
X(1,  JrOffset,				'J')	// 8-bit relative offset for JR
X(2,  ByteUnsigned,			'U')   	// 8-bit unsigned
X(3,  ByteSigned,			'S')   	// 8-bit signed
X(4,  Word,					'C')	// 16-bit value little-endian
X(5,  WordBE,				'B')	// 16-bit value big-endian
X(6,  DWord,				'L')	// 32-bit signed
X(7,  ByteToWordUnsigned,	'u')	// unsigned byte extended to 16 bits
X(8,  ByteToWordSigned,		's')	// signed byte sign-extended to 16 bits
X(9,  Ptr24,				'P')	// 24-bit pointer
X(10, HighOffset,			'H')	// byte offset to 0xFF00
X(11, Assignment,			'=')	// DEFC expression assigning a symbol
X(12, JreOffset,			'j')    // 16-bit relative offset for JRE
X(13, ByteToPtrUnsigned, 	'v')   	// unsigned byte extended to 24 bits
X(14, ByteToPtrSigned, 		't')	// signed byte sign-extended to 24 bits

#undef X
