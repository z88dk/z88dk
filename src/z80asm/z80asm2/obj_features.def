X(has_expr_asmpc_dword,     v >= 17)
X(has_expr_asmpc_word,      v >= 3 && v < 17)
X(has_expr_file_line,       v >= 4 )
X(has_expr_opcode_size,     v >= 17)
X(has_expr_patch_ptr_dword, v >= 17)
X(has_expr_range_dword,     v >= 18)
X(has_expr_target_name,     v >= 6 )
X(has_expr_word_text,       v >= 4 )
X(has_file_data_aligned,	v >= 18)
X(has_global_cpu,           v >= 18)
X(has_global_org_dword,     v >= 5  && v < 8)
X(has_global_org_word,      v >= 1  && v < 5)
X(has_relocs,               v >= 19)
X(has_section_align,        v >= 10)
X(has_section_org,          v >= 8 )
X(has_sections,             v >= 5 )
X(has_string_table,         v >= 18)
X(has_symbol_file_line,     v >= 9 )
X(has_symbol_index,         v >= 19)
X(has_symbol_scope_dword,   v >= 18)
X(has_symbol_type_dword,    v >= 18)
X(has_word_strings,         v >= 16)
