// Code supported CPUs, their names, and defines for the preprocessor
// the ancestor is the CPU that is compatible with this CPU
// the non_strict is the non-strict version of this CPU

//id,   name,               name_str,           non_strict, ancestor,   defines
X(0,    none,               "",                 none,       none,       "")
X(1,    z80,                "z80",              z80,        i8080,      "__CPU_ZILOG__ __CPU_Z80__")
X(2,    z80_strict,         "z80_strict",       z80,        i8080,      "__CPU_ZILOG__ __CPU_Z80_STRICT__")
X(3,    z180,               "z180",             z180,       i8080,      "__CPU_ZILOG__ __CPU_Z180__")
X(4,    ez80_z80,           "ez80_z80",         ez80_z80,   none,       "__CPU_ZILOG__ __CPU_EZ80_Z80__")
X(5,    ez80,               "ez80",             ez80,       none,       "__CPU_ZILOG__ __CPU_EZ80__")
X(6,    z80n,               "z80n",             z80n,       z80,        "__CPU_ZILOG__ __CPU_Z80N__")
X(7,    r2ka,               "r2ka",             r2ka,       none,       "__CPU_RABBIT__ __CPU_R2KA__")
X(8,    r3k,                "r3k",              r3k,        r2ka,       "__CPU_RABBIT__ __CPU_R3K__")
X(9,    gbz80,              "gbz80",            gbz80,      none,       "__CPU_GBZ80__")
X(10,   i8080,              "8080",             i8080,      none,       "__CPU_INTEL__ __CPU_8080__")
X(11,   i8085,              "8085",             i8085,      i8080,      "__CPU_INTEL__ __CPU_8085__")
X(12,   r800,               "r800",             r800,       i8080,      "__CPU_R800__")
X(13,   r4k,                "r4k",              r4k,        none,       "__CPU_RABBIT__ __CPU_R4K__")
X(14,   r5k,                "r5k",              r5k,        r4k,        "__CPU_RABBIT__ __CPU_R5K__")
X(15,   kc160,              "kc160",            kc160,      none,       "__CPU_KC160__")
X(16,   kc160_z80,          "kc160_z80",        kc160_z80,  i8080,      "__CPU_KC160_Z80__")
X(17,   i8080_strict,       "8080_strict",      i8080,      none,       "__CPU_INTEL__ __CPU_8080_STRICT__")
X(18,   i8085_strict,       "8085_strict",      i8085,      i8080,      "__CPU_INTEL__ __CPU_8085_STRICT__")
X(19,   gbz80_strict,       "gbz80_strict",     gbz80,      none,       "__CPU_GBZ80_STRICT__")
X(20,   z180_strict,        "z180_strict",      z180,       i8080,      "__CPU_ZILOG__ __CPU_Z180_STRICT__")
X(21,   z80n_strict,        "z80n_strict",      z80n,       z80,        "__CPU_ZILOG__ __CPU_Z80N_STRICT__")
X(22,   ez80_z80_strict,    "ez80_z80_strict",  ez80_z80,   none,       "__CPU_ZILOG__ __CPU_EZ80_Z80_STRICT__")
X(23,   ez80_strict,        "ez80_strict",      ez80,       none,       "__CPU_ZILOG__ __CPU_EZ80_STRICT__")
X(24,   r800_strict,        "r800_strict",      r800,       i8080,      "__CPU_R800_STRICT__")
X(25,   kc160_strict,       "kc160_strict",     kc160,      none,       "__CPU_KC160_STRICT__")
X(26,   kc160_z80_strict,   "kc160_z80_strict", kc160_z80,  i8080,      "__CPU_KC160_Z80_STRICT__")
X(27,   r2ka_strict,        "r2ka_strict",      r2ka,       none,       "__CPU_RABBIT__ __CPU_R2KA_STRICT__")
X(28,   r3k_strict,         "r3k_strict",       r3k,        r2ka,       "__CPU_RABBIT__ __CPU_R3K_STRICT__")
X(29,   r4k_strict,         "r4k_strict",       r4k,        none,       "__CPU_RABBIT__ __CPU_R4K_STRICT__")
X(30,   r5k_strict,         "r5k_strict",       r5k,        r4k,        "__CPU_RABBIT__ __CPU_R5K_STRICT__")
X(31,   r6k,                "r6k",              r6k,        r5k,        "__CPU_RABBIT__ __CPU_R6K__")
X(32,   r6k_strict,         "r6k_strict",       r6k,        r5k,        "__CPU_RABBIT__ __CPU_R6K_STRICT__")
X(33,   ti83,               "ti83",             ti83,       z80,        "__CPU_ZILOG__ __CPU_TI83__")
X(34,   ti83_strict,        "ti83_strict",      ti83,       z80,        "__CPU_ZILOG__ __CPU_TI83_STRICT__")
X(35,   ti83plus,           "ti83plus",         ti83plus,   z80,        "__CPU_ZILOG__ __CPU_TI83PLUS__")
X(36,   ti83plus_strict,    "ti83plus_strict",  ti83plus,   z80,        "__CPU_ZILOG__ __CPU_TI83PLUS_STRICT__")

#undef X
